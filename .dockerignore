# Build artifacts — re-generated inside Docker
.next/
/build
/out

# Version control
.git/
.gitignore

# Environment files — injected at runtime via docker-compose
.env
.env.local
.env.*.local

# IDE / editor files
.idea/
*.iml

# OS artefacts
.DS_Store
*.pem

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript incremental build cache
*.tsbuildinfo
next-env.d.ts

# NOTE: node_modules is intentionally NOT excluded here.
# Packages are pre-installed on the host before running `docker compose build`
# because the Docker build container does not have outbound internet access
# to reach the npm registry. See README — Docker section for setup steps.
