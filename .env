# ============================================================
# Sembako-Chain AI — Environment Variables
# ============================================================
# Untuk DEVELOPMENT LOKAL. Jangan commit file ini.
# ============================================================

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://sembako:sembako_pass@localhost:5432/sembako_chain_ai
DB_PORT=5433

# ---- Aplikasi ----
APP_URL=http://localhost:3300
APP_PORT=3300

# ---- NextAuth ----
NEXTAUTH_URL=http://localhost:3300
NEXTAUTH_SECRET=dev-secret-change-in-production

# ---- API ----
NEXT_PUBLIC_API_URL=http://localhost:3300/api

# ---- Seed Database ----
# Set ke false setelah pertama kali berhasil
SEED_DB=true
