# ============================================================
# Sembako-Chain AI — Environment Variables
# ============================================================
# Salin file ini ke .env:  cp .env.example .env

# ---- Database ----
# Format: postgresql://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL="postgresql://sembako:sembako_pass@localhost:5432/sembako_chain_ai"

# ---- NextAuth ----
NEXTAUTH_URL="http://localhost:3300"
# Generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-secret-acak-yang-aman"

# ---- API ----
NEXT_PUBLIC_API_URL="http://localhost:3300/api"
