# ============================================================
# Sembako-Chain AI — Environment Variables (TEMPLATE)
# ============================================================
# Salin ke .env:  cp .env.example .env
# Lalu sesuaikan nilainya.
# ============================================================

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://user:password@localhost:5432/sembako_chain_ai
DB_PORT=5433

# ---- Aplikasi ----
# DEVELOPMENT: http://localhost:3300
# SERVER:       https://domain-anda.com
APP_URL=http://localhost:3300
APP_PORT=3300

# ---- NextAuth ----
# DEVELOPMENT: http://localhost:3300
# SERVER:       https://domain-anda.com
NEXTAUTH_URL=http://localhost:3300
# Generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET=ganti-dengan-random-string-minimal-32-karakter

# ---- API ----
# DEVELOPMENT: http://localhost:3300/api
# SERVER:       https://domain-anda.com/api
NEXT_PUBLIC_API_URL=http://localhost:3300/api

# ---- Seed Database ----
# Set ke false setelah pertama kali berhasil
SEED_DB=true
